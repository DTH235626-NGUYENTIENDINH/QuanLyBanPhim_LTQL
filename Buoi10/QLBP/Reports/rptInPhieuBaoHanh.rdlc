<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="QLBPDataSet">
      <ConnectionProperties>
        <DataProvider>System.Data.DataSet</DataProvider>
        <ConnectString>/* Local Connection */</ConnectString>
      </ConnectionProperties>
      <rd:DataSourceID>68a55cc8-2f16-4d5f-870d-f5e1f0e4b868</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DanhSachHoaDon_ChiTiet">
      <Query>
        <DataSourceName>QLBPDataSet</DataSourceName>
        <CommandText>/* Local Query */</CommandText>
      </Query>
      <Fields>
        <Field Name="ID">
          <DataField>ID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TenBP">
          <DataField>TenBP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SoLuongBan">
          <DataField>SoLuongBan</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="ThoiGianBaoHanh">
          <DataField>ThoiGianBaoHanh</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <Textbox Name="Textbox1">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>PHIẾU BẢO HÀNH</Value>
                    <Style>
                      <FontSize>20pt</FontSize>
                      <FontWeight>Bold</FontWeight>
                      <Color>Fuchsia</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style>
                  <TextAlign>Center</TextAlign>
                </Style>
              </Paragraph>
            </Paragraphs>
            <Top>0.2in</Top>
            <Left>0in</Left>
            <Height>0.4in</Height>
            <Width>6.5in</Width>
          </Textbox>
          
          <Textbox Name="Info">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>="Khách hàng: " &amp; Parameters!NguoiMua_Ten.Value &amp; Environment.NewLine &amp; "Số hóa đơn: " &amp; Parameters!MaHD.Value &amp; Environment.NewLine &amp; "Ngày mua: " &amp; Parameters!NgayLap.Value</Value>
                    <Style><FontSize>11pt</FontSize></Style>
                  </TextRun>
                </TextRuns>
              </Paragraph>
            </Paragraphs>
            <Top>0.7in</Top>
            <Left>0.5in</Left>
            <Height>0.8in</Height>
            <Width>5.5in</Width>
          </Textbox>

          <Tablix Name="Tablix1">
            <TablixBody>
              <TablixColumns>
                <TablixColumn><Width>0.5in</Width></TablixColumn>
                <TablixColumn><Width>3in</Width></TablixColumn>
                <TablixColumn><Width>1.5in</Width></TablixColumn>
                <TablixColumn><Width>1in</Width></TablixColumn>
              </TablixColumns>
              <TablixRows>
                <TablixRow>
                  <Height>0.3in</Height>
                  <TablixCells>
                    <TablixCell><CellContents><Textbox Name="h1"><Paragraphs><Paragraph><TextRuns><TextRun><Value>STT</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><BackgroundColor>Plum</BackgroundColor><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="h2"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Tên Sản Phẩm</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><BackgroundColor>Plum</BackgroundColor><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="h3"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Thời gian BH</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><BackgroundColor>Plum</BackgroundColor><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="h4"><Paragraphs><Paragraph><TextRuns><TextRun><Value>SL</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><BackgroundColor>Plum</BackgroundColor><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  </TablixCells>
                </TablixRow>
                <TablixRow>
                  <Height>0.3in</Height>
                  <TablixCells>
                    <TablixCell><CellContents><Textbox Name="d1"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=RowNumber(Nothing)</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="d2"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!TenBP.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="d3"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!ThoiGianBaoHanh.Value &amp; " tháng"</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="d4"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!SoLuongBan.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  </TablixCells>
                </TablixRow>
              </TablixRows>
            </TablixBody>
            <TablixColumnHierarchy><TablixMembers><TablixMember/><TablixMember/><TablixMember/><TablixMember/></TablixMembers></TablixColumnHierarchy>
            <TablixRowHierarchy><TablixMembers><TablixMember><KeepWithGroup>After</KeepWithGroup></TablixMember><TablixMember><Group Name="Details"/></TablixMember></TablixMembers></TablixRowHierarchy>
            <DataSetName>DanhSachHoaDon_ChiTiet</DataSetName>
            <Top>1.6in</Top>
            <Left>0.5in</Left>
            <Height>0.6in</Height>
            <Width>5in</Width>
          </Tablix>
          
          <Textbox Name="Footer">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>Quý khách vui lòng giữ phiếu này để được hỗ trợ bảo hành tốt nhất.</Value>
                    <Style><FontStyle>Italic</FontStyle></Style>
                  </TextRun>
                </TextRuns>
                <Style><TextAlign>Center</TextAlign></Style>
              </Paragraph>
            </Paragraphs>
            <Top>2.5in</Top>
            <Left>0in</Left>
            <Height>0.3in</Height>
            <Width>6.5in</Width>
          </Textbox>
        </ReportItems>
        <Height>3.5in</Height>
      </Body>
      <Width>6.5in</Width>
      <Page>
        <Style/>
      </Page>
    </ReportSection>
  </ReportSections>
  <ReportParameters>
    <ReportParameter Name="NguoiMua_Ten"><DataType>String</DataType><Prompt>NguoiMua_Ten</Prompt></ReportParameter>
    <ReportParameter Name="MaHD"><DataType>String</DataType><Prompt>MaHD</Prompt></ReportParameter>
    <ReportParameter Name="NgayLap"><DataType>String</DataType><Prompt>NgayLap</Prompt></ReportParameter>
  </ReportParameters>
</Report>
