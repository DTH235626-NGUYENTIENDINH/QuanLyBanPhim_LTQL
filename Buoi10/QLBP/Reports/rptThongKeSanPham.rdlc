                  </Paragraph>
                </Paragraphs>
              </Textbox>
            </ReportItems>
            <Top>0.5in</Top><Left>0in</Left><Height>0.5in</Height><Width>6.5in</Width>
          </Rectangle>
          <Textbox Name="Title">
            <Top>0.1in</Top><Left>0in</Left><Height>0.35in</Height><Width>6.5in</Width>
            <Paragraphs>
              <Paragraph>
                <TextRuns><TextRun><Value>BÁO CÁO PHÂN TÍCH HÀNG TỒN KHO</Value><Style><FontSize>16pt</FontSize><FontWeight>Bold</FontWeight><Color>#2c3e50</Color></Style></TextRun></TextRuns>
                <Style><TextAlign>Center</TextAlign></Style>
              </Paragraph>
            </Paragraphs>
          </Textbox>
          <Textbox Name="MoTa">
            <Top>1in</Top><Left>0in</Left><Height>0.25in</Height><Width>6.5in</Width>
            <Paragraphs>
              <Paragraph>
                <TextRuns><TextRun><Value>=Parameters!MoTaKetQuaHienThi.Value</Value><Style><FontStyle>Italic</FontStyle><Color>#7f8c8d</Color></Style></TextRun></TextRuns>
                <Style><TextAlign>Center</TextAlign></Style>
              </Paragraph>
            </Paragraphs>
          </Textbox>
          <Tablix Name="Tablix1">
            <TablixBody>
              <TablixColumns>
