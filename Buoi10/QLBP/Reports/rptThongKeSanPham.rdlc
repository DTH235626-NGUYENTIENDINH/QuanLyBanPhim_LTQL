        <Field Name="SoLuong"><DataField>SoLuong</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <Rectangle Name="RectangleDashboard">
            <ReportItems>
              <Textbox Name="TextboxTongVon">
                <Style><BackgroundColor>#2c3e50</BackgroundColor><PaddingTop>5pt</PaddingTop></Style>
                <Top>0.1in</Top><Left>0.1in</Left><Height>0.3in</Height><Width>2in</Width>
                <Paragraphs>
                  <Paragraph>
                    <TextRuns><TextRun><Value>="TỔNG VỐN TỒN: " &amp; Parameters!TongVonTonKho.Value</Value><Style><FontSize>10pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns>
                    <Style><TextAlign>Center</TextAlign></Style>
                  </Paragraph>
                </Paragraphs>
