                <TablixColumn><Width>1.2in</Width></TablixColumn>
                <TablixColumn><Width>1.1in</Width></TablixColumn>
                <TablixColumn><Width>1.2in</Width></TablixColumn>
              </TablixColumns>
              <TablixRows>
                <TablixRow>
                  <Height>0.3in</Height>
                  <TablixCells>
                    <TablixCell><CellContents><Textbox Name="H1"><Style><BackgroundColor>#34495e</BackgroundColor><PaddingLeft>2pt</PaddingLeft><PaddingTop>4pt</PaddingTop></Style><Paragraphs><Paragraph><TextRuns><TextRun><Value>ID</Value><Style><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="H2"><Style><BackgroundColor>#34495e</BackgroundColor><PaddingLeft>2pt</PaddingLeft><PaddingTop>4pt</PaddingTop></Style><Paragraphs><Paragraph><TextRuns><TextRun><Value>TÊN SẢN PHẨM</Value><Style><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="H3"><Style><BackgroundColor>#34495e</BackgroundColor><PaddingLeft>2pt</PaddingLeft><PaddingTop>4pt</PaddingTop></Style><Paragraphs><Paragraph><TextRuns><TextRun><Value>HÃNG SX</Value><Style><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="H4"><Style><BackgroundColor>#34495e</BackgroundColor><PaddingLeft>2pt</PaddingLeft><PaddingTop>4pt</PaddingTop></Style><Paragraphs><Paragraph><TextRuns><TextRun><Value>SỐ LƯỢNG</Value><Style><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="H5"><Style><BackgroundColor>#34495e</BackgroundColor><PaddingLeft>2pt</PaddingLeft><PaddingTop>4pt</PaddingTop></Style><Paragraphs><Paragraph><TextRuns><TextRun><Value>GIÁ BÁN</Value><Style><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                  </TablixCells>
                </TablixRow>
                <TablixRow>
                  <Height>0.25in</Height>
                  <TablixCells>
                    <TablixCell><CellContents><Textbox Name="C1"><Style><Border><Color>LightGrey</Color><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!ID.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="C2"><Style><Border><Color>LightGrey</Color><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!TenBP.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="C3"><Style><Border><Color>LightGrey</Color><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!TenHangSanXuat.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="C4"><Style><Border><Color>LightGrey</Color><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!SoLuong.Value</Value><Style><Color>=IIf(Fields!SoLuong.Value &lt; 5, "Red", "Black")</Color><FontWeight>=IIf(Fields!SoLuong.Value &lt; 5, "Bold", "Normal")</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="C5"><Style><Border><Color>LightGrey</Color><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!GiaBan.Value</Value><Style><Format>N0</Format></Style></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                  </TablixCells>
                </TablixRow>
              </TablixRows>
            </TablixBody>
            <TablixColumnHierarchy><TablixMembers><TablixMember/><TablixMember/><TablixMember/><TablixMember/><TablixMember/></TablixMembers></TablixColumnHierarchy>
