    <ReportParameter Name="TongVonTonKho"><DataType>String</DataType><AllowBlank>true</AllowBlank><Prompt>TongVon</Prompt></ReportParameter>
    <ReportParameter Name="TongSoLuong"><DataType>String</DataType><AllowBlank>true</AllowBlank><Prompt>TongSL</Prompt></ReportParameter>
    <ReportParameter Name="SoSPCanNhap"><DataType>String</DataType><AllowBlank>true</AllowBlank><Prompt>CanNhap</Prompt></ReportParameter>
