                <Top>0.1in</Top><Left>4.4in</Left><Height>0.3in</Height><Width>2in</Width>
                <Paragraphs>
                  <Paragraph>
                    <TextRuns><TextRun><Value>="SẮP HẾT HÀNG: " &amp; Parameters!SoSPCanNhap.Value</Value><Style><FontSize>10pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns>
