                <Top>0.1in</Top><Left>2.25in</Left><Height>0.3in</Height><Width>2in</Width>
                <Paragraphs>
                  <Paragraph>
                    <TextRuns><TextRun><Value>="TỔNG SỐ LƯỢNG: " &amp; Parameters!TongSoLuong.Value</Value><Style><FontSize>10pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns>
                    <Style><TextAlign>Center</TextAlign></Style>
                  </Paragraph>
